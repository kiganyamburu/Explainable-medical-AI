# ==============================================================================
# Explainable Medical AI - Environment Configuration Template
# Copy this file to '.env' and fill in your details to override configurations.
# ==============================================================================

# Flask environment configuration
FLASK_ENV=development
SECRET_KEY=dev-medical-ai-secret-key-123456789
FLASK_DEBUG=True
PORT=5000

# Database Configuration
# By default, the application falls back to a local SQLite database at:
# /app/database/pneumonia.db
# To connect to a PostgreSQL database, uncomment the line below and replace with your credentials:
# DATABASE_URL=postgresql://username:8777@localhost:5432/Explainablemedicaldb

# Machine Learning & Dataset paths
# DATASET_DIR=C:\path\to\your\Kaggle\chest_xray
